# Copy to .env and fill in to enable real Azure integration.
# Leave blank for offline simulation mode (default).
#
# Data-plane auth: API keys are OPTIONAL. When the *_API_KEY values are blank,
# the app falls back to DefaultAzureCredential (azure-identity) and acquires a
# bearer token — required when your tenant policy disables local auth.
# Run `az login` so DefaultAzureCredential can pick up your identity.

# --- Azure OpenAI embeddings (real embeddings instead of simulation) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

# --- Azure AI Search (push optimized index for Foundry agents) ---
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_API_KEY=
AZURE_AI_SEARCH_INDEX=rag-cost-demo

# --- Foundry agent (optional: route queries through a real agent) ---
# FOUNDRY_PROJECT_ENDPOINT is populated by `azd provision`.
# FOUNDRY_AGENT_ID is set manually after you create an agent in the Foundry
# portal (or via `python backend/scripts/setup_foundry_agent.py`).
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_AGENT_ID=

# --- Pricing (USD per 1M tokens; override to match your contract) ---
PRICE_PER_MTOKEN_EMBEDDING=0.02
EMBEDDING_MODEL_NAME=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
